{
  "name": "editorial-estate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "node ./node_modules/vite/bin/vite.js",
    "dev:server": "node ./node_modules/tsx/dist/cli.mjs watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "node ./node_modules/vite/bin/vite.js build",
    "build:server": "node ./node_modules/typescript/bin/tsc -p tsconfig.server.json",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "start": "node ./dist-server/server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
